+async function startSpeakerEdit(el) {
+  if (el.dataset.editing === '1') return;
+  el.dataset.editing = '1';
+  const oldValue = el.textContent.trim();
+  const rowIdx = parseInt(el.dataset.rowIdx, 10);
+  const candidates = Array.isArray(currentProject?.participants)
+    ? currentProject.participants.map(p => p.name).filter(Boolean)
+    : [];
+  const options = Array.from(new Set([oldValue, ...candidates, '未設定']))
+                       .filter(Boolean);
+
+  const select = document.createElement('select');
+  select.className = 'speaker-select';
+  options.forEach(name => {
+    const o = document.createElement('option');
+    o.value = name; o.textContent = name;
+    if (name === oldValue) o.selected = true;
+    select.appendChild(o);
+  });
+  const origColor = el.style.color;
+  el.innerHTML = '';
+  el.appendChild(select);
+  select.focus();
+
+  let done = false;
+  const finish = async () => {
+    if (done) return; done = true;
+    const newValue = select.value;
+    if (newValue === oldValue) {
+      el.textContent = oldValue;
+      el.dataset.editing = '';
+      return;
+    }
+    try {
+      const res = await apiFetch(
+        `/api/projects/${currentProject.id}/merged/speaker`,
+        { method: 'PATCH',
+          headers: {'content-type': 'application/json'},
+          body: JSON.stringify({ row_idx: rowIdx, speaker: newValue }) }
+      );
+      if (!res.ok) throw new Error(await res.text());
+      el.textContent = newValue;
+      const newIdx = currentProject.participants.findIndex(pt => pt.name === newValue);
+      el.style.color = newIdx >= 0
+        ? SPEAKER_COLORS[newIdx % SPEAKER_COLORS.length]
+        : (newValue === '未設定' ? 'var(--sub)' : 'var(--purple)');
+      if (currentProject.merged?.result?.[rowIdx]) {
+        currentProject.merged.result[rowIdx].speaker = newValue;
+      }
+    } catch (e) {
+      alert('話者変更に失敗: ' + e.message);
+      el.textContent = oldValue;
+      el.style.color = origColor;
+    } finally {
+      el.dataset.editing = '';
+    }
+  };
+  select.addEventListener('change', finish);
+  select.addEventListener('blur', finish);
+}
