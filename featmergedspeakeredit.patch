+// File System Access API でダウンロードフォルダから開く（Chrome/Edge）
+async function pickAudioFilesFromDownloads() {
+  const input = document.getElementById('zoom-up-files');
+  if (!window.showOpenFilePicker) {
+    // 非対応ブラウザは通常 input を起動
+    input.click();
+    return;
+  }
+  try {
+    const handles = await window.showOpenFilePicker({
+      multiple: true,
+      startIn: 'downloads',
+      types: [{
+        description: '音声ファイル',
+        accept: {'audio/*': ['.m4a','.mp4','.wav','.mp3','.webm','.ogg','.flac']},
+      }],
+    });
+    const files = await Promise.all(handles.map(h => h.getFile()));
+    // input.files に転送（DataTransfer 経由）
+    const dt = new DataTransfer();
+    files.forEach(f => dt.items.add(f));
+    input.files = dt.files;
+    onZoomFilesChange();
+  } catch (e) {
+    if (e.name !== 'AbortError') {
+      console.error('file picker failed', e);
+      input.click(); // フォールバック
+    }
+  }
+}
